# Copy this file to .env and uncomment the lines you want to override.
# Every variable is optional — the defaults work out of the box.

# ─── Concurrency ────────────────────────────────────────────────────────────
#
# PLAYWRIGHT_CONCURRENCY
#   Max number of browser pages open at once.
#   Playwright is the dominant RAM consumer (~150–300 MB per page).
#   Rule of thumb: 1 page per 300 MB of free RAM, up to 2× CPU cores.
#
#   RAM   CPUs  Recommended
#   1 GB   2      2
#   2 GB   2      3
#   4 GB   4      5   ← default
#   8 GB   4      8
#   8 GB   8     10
#
# PLAYWRIGHT_CONCURRENCY=5

# FETCH_CONCURRENCY
#   Max number of simultaneous plain-HTTP fetch requests.
#   Fetch is pure network I/O — RAM/CPU are not the constraint.
#   Without proxy: keep low (10–20) to avoid triggering rate limits.
#   With a rotating datacenter proxy: 50–100 is fine.
#
# FETCH_CONCURRENCY=50

# BATCH_CONCURRENCY
#   Max number of batch queue items processed in parallel.
#   Each slot can hold a fetch, a playwright scrape, or both.
#   Should be at least as large as PLAYWRIGHT_CONCURRENCY so the
#   browser pool is never left idle waiting for a batch slot.
#
#   A good default: PLAYWRIGHT_CONCURRENCY + a few extra slots for
#   fetch-only items that complete quickly.
#   e.g. PLAYWRIGHT_CONCURRENCY=5 → BATCH_CONCURRENCY=8
#
# BATCH_CONCURRENCY=5


# ─── Proxies ────────────────────────────────────────────────────────────────
#
# PROXY_DATACENTER
#   HTTP proxy used for the fetch scraper.
#   Recommended: Webshare rotating datacenter endpoint.
#   Find the URL in: Webshare dashboard → Proxy → Access credentials
#
# PROXY_DATACENTER=http://username:password@p.webshare.io:80

# PROXY_RESIDENTIAL
#   HTTP proxy used for the Playwright scraper.
#   Recommended: Webshare rotating residential endpoint.
#   Residential IPs are less likely to hit CAPTCHAs on protected sites.
#
# PROXY_RESIDENTIAL=http://username:password@p.webshare.io:8080


# ─── Database ────────────────────────────────────────────────────────────────
#
# Override the SQLite file location (default: ./data/imsometa.db).
# Rarely needed — only change this if your Docker volume is mounted elsewhere.
#
# DATABASE_PATH=/custom/path/imsometa.db
